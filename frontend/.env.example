# Production Backend HTTP REST API URL (Render / Railway API URL)
# Example: VITE_API_URL=https://intellmeet-backend.onrender.com/api
# Leave empty in local development to automatically fall back to http://localhost:5000/api
VITE_API_URL=

# Production Backend WebSockets Server URL (Render / Railway host URL)
# Example: VITE_SOCKET_URL=https://intellmeet-backend.onrender.com
# Leave empty in local development to automatically fall back to http://localhost:5000
VITE_SOCKET_URL=

# Google OAuth 2.0 Client ID for Google Sign-in authentication
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
