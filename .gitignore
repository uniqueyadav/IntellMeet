# Dependency directories (ignore third-party node packages)
node_modules/
**/node_modules/
jspm_packages/
web_modules/

# Environment files (ignore secret keys and local configs)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
**/.env
**/.env.local
**/.env*.local

# Production build outputs
dist/
build/
out/
.next/
.nuxt/
frontend/dist/

# Debug and log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# System files
.DS_Store
Thumbs.db

# Editor configurations and IDE metadata
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
